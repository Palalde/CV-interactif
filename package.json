{
  "name": "cv-interactif",
  "private": true,
  "version": "0.0.0",
  "description": "Site statique: CV interactif avec Xterm console",
  "license": "UNLICENSED",
  "scripts": {
    "build": "npm run build:console",
    "build:console": "node node_modules/esbuild/bin/esbuild js/dev/console-src/index.js --bundle --minify --sourcemap --outdir=js/dev/dist --format=iife --target=es2020",
    "watch:console": "node node_modules/esbuild/bin/esbuild js/dev/console-src/index.js --bundle --sourcemap --outdir=js/dev/dist --format=iife --target=es2020 --watch"
  },
  "dependencies": {
    "xterm": "5.3.0",
    "xterm-addon-fit": "0.8.0",
    "esbuild": "^0.23.0"
  },
  "devDependencies": {
  },
  "overrides": {}
}
